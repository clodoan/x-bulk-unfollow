{
  "manifest_version": 3,
  "name": "X Bulk Unfollow",
  "short_name": "UnfollowX",
  "version": "0.1.0",
  "description": "Bulk unfollow accounts you follow on X using the official X API v2. Rate-limit aware, private, no data collection.",
  "author": "Claudio",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://api.x.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "X Bulk Unfollow",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "web_accessible_resources": [],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
